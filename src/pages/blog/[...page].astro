---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { SITE, POSTS_PER_PAGE } from '../../config';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection('posts', ({ data }) => !data.draft);
  const sortedPosts = allPosts.sort((a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return b.data.date.getTime() - a.data.date.getTime();
  });
  return paginate(sortedPosts, { pageSize: POSTS_PER_PAGE });
}) satisfies GetStaticPaths;

const { page } = Astro.props;

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => {
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  return b.data.date.getTime() - a.data.date.getTime();
});
const categories = [...new Set(sortedPosts.map((p) => p.data.category))];

function formatDate(d: Date): string {
  return d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

function estimateReadTime(description: string): number {
  return Math.max(3, Math.ceil(description.length / 40));
}

const pageNum = page.currentPage;
const pageTitle = pageNum === 1 ? 'Blog' : `Blog — Page ${pageNum}`;

const total = page.lastPage;
const paginationPages: (number | string)[] = [];
if (total <= 7) {
  for (let i = 1; i <= total; i++) paginationPages.push(i);
} else {
  paginationPages.push(1);
  if (pageNum > 3) paginationPages.push('...');
  const start = Math.max(2, pageNum - 1);
  const end = Math.min(total - 1, pageNum + 1);
  for (let i = start; i <= end; i++) paginationPages.push(i);
  if (pageNum < total - 2) paginationPages.push('...');
  paginationPages.push(total);
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: `${pageTitle} — ${SITE.name}`,
  url: new URL(pageNum === 1 ? '/blog/' : `/blog/${pageNum}/`, SITE.url).toString(),
  description: 'Thoughts on WordPress, web development, and the tools I use.',
};
---

<BaseLayout
  title={pageTitle}
  description="Thoughts on WordPress, web development, and the tools I use."
  jsonLd={jsonLd}
>
  <main class="container">
    <div class="page-title">
      <h1>Writing</h1>
      <p>Thoughts on WordPress, web development, and the tools I use.</p>
    </div>

    <div class="filter-bar">
      {
        categories.map((cat) => {
          const slug = sortedPosts.find((p) => p.data.category === cat)?.data
            .categorySlug;
          return (
            <a href={`/${slug}/`} class="filter-pill">
              {cat}
            </a>
          );
        })
      }
    </div>

    <div class="card-group">
      {
        page.data.map((post: any) => (
          <a href={`/${post.id}/`} class="hover-card blog-full-item">
            <div class="card-bg" />
            <div>
              <div class="blog-full-cat">
                {post.data.featured && <span class="featured-badge">Featured</span>}
                {post.data.category}
              </div>
              <h2 class="blog-full-title">{post.data.title}</h2>
              <p class="blog-full-excerpt">{post.data.description}</p>
              <div class="blog-full-meta">
                {formatDate(post.data.date)} ·{' '}
                {estimateReadTime(post.data.description)} min read
              </div>
            </div>
          </a>
        ))
      }
    </div>

    {
      total > 1 && (
        <nav class="pagination" aria-label="Blog pagination">
          {page.url.prev && (
            <a href={page.url.prev} class="pag-prev">&larr; Prev</a>
          )}
          {paginationPages.map((p) =>
            p === '...' ? (
              <span class="ellipsis">&hellip;</span>
            ) : p === pageNum ? (
              <span class="current" aria-current="page">{p}</span>
            ) : (
              <a href={p === 1 ? '/blog/' : `/blog/${p}/`}>{p}</a>
            )
          )}
          {page.url.next && (
            <a href={page.url.next} class="pag-next">Next &rarr;</a>
          )}
        </nav>
      )
    }
  </main>
</BaseLayout>
