---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, AUTHOR } from '../config';

const lastUpdated = 'April 15, 2026';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: `Privacy, Terms & Disclaimer — ${SITE.name}`,
  url: new URL('/privacy/', SITE.url).toString(),
};
---

<BaseLayout
  title="Privacy, Terms & Disclaimer"
  description={`Privacy policy, terms of use, and disclaimer for ${SITE.name}. Covers comments, affiliate links, newsletter, cookies, and GDPR compliance.`}
  jsonLd={jsonLd}
>
  <main class="container">
    <div class="page-title">
      <h1>Privacy, Terms & Disclaimer</h1>
      <p>Last updated: {lastUpdated}</p>
    </div>

    <div class="prose" style="padding-top:16px">

      <h2>Who I am</h2>
      <p>
        This website is operated by {AUTHOR.name}. The site address is
        <a href={SITE.url}>{SITE.url}</a>. If you have questions about this
        policy, you can reach me through the links on the
        <a href="/contact/">contact page</a>.
      </p>

      <h2>Comments</h2>
      <p>
        Comments on this site are powered by <a href="https://giscus.app" target="_blank" rel="noopener noreferrer">Giscus</a>,
        which uses <a href="https://docs.github.com/en/discussions" target="_blank" rel="noopener noreferrer">GitHub Discussions</a>
        as its backend. When you leave a comment, you sign in with your GitHub account. Your comment,
        GitHub username, and profile picture are stored on GitHub's servers and are subject to
        <a href="https://docs.github.com/en/site-policy/privacy-policies/github-general-privacy-statement" target="_blank" rel="noopener noreferrer">GitHub's privacy policy</a>.
        I do not collect or store any additional data from commenters on my own servers.
      </p>

      <h2>Affiliate links and disclaimer</h2>
      <p>
        Some posts on this site may contain affiliate links. This means that if you click on a link and
        make a purchase, I may receive a small commission at no extra cost to you. I only recommend
        products and services that I have personally used or believe will be genuinely useful.
      </p>
      <p>
        Affiliate relationships on this site may include, but are not limited to, hosting providers,
        WordPress plugins, and other digital products. All opinions expressed are my own and are not
        influenced by any compensation I may receive.
      </p>
      <p>
        The content on this site is provided for informational purposes only. I do my best to keep
        everything accurate and up to date, but I make no guarantees about the completeness or
        accuracy of any information published here. You use any code, advice, or recommendations
        at your own risk.
      </p>

      <h2>Newsletter</h2>
      <p>
        This site has a weekly newsletter powered by <a href="https://mailchimp.com" target="_blank" rel="noopener noreferrer">Mailchimp</a>.
        When you subscribe, your email address is stored on Mailchimp's servers and is subject to
        <a href="https://www.intuit.com/privacy/statement/" target="_blank" rel="noopener noreferrer">Mailchimp's privacy policy</a>.
        Your email will only be used to send you the newsletter. I will not share it with anyone else.
        You can unsubscribe at any time using the link included in every email.
      </p>

      <h2>Ko-fi</h2>
      <p>
        If you support me through <a href="https://ko-fi.com" target="_blank" rel="noopener noreferrer">Ko-fi</a>,
        your payment information is handled entirely by Ko-fi and their payment processor (PayPal or Stripe).
        I do not have access to your payment details. Please refer to
        <a href="https://more.ko-fi.com/privacy" target="_blank" rel="noopener noreferrer">Ko-fi's privacy policy</a>
        for details on how they handle your data.
      </p>

      <h2>Cookies and analytics</h2>
      <p>
        This site stores your theme preference (light or dark mode) in your browser's localStorage.
        This is not a cookie and is not sent to any server. It stays on your device.
      </p>
      <p>
        I do not use any analytics or tracking scripts on this site. No Google Analytics, no Facebook Pixel,
        no third-party trackers. If I add analytics in the future, this page will be updated, and I will
        use a privacy-respecting solution.
      </p>

      <h2>Embedded content</h2>
      <p>
        Posts on this site may include embedded content from other websites (videos, images, code embeds, etc.).
        Embedded content from other websites behaves the same way as if you visited that website directly.
        These websites may collect data about you, use cookies, embed additional third-party tracking,
        and monitor your interaction with that embedded content.
      </p>

      <h2>External links</h2>
      <p>
        This site contains links to external websites. I am not responsible for the content or privacy
        practices of those sites. When you click an external link, you leave this site and are subject
        to the privacy policy of the destination site.
      </p>

      <h2>Your rights under GDPR</h2>
      <p>
        If you are located in the European Union or European Economic Area, you have the right to:
      </p>
      <ul>
        <li>Access the personal data I hold about you.</li>
        <li>Request correction of inaccurate data.</li>
        <li>Request deletion of your data.</li>
        <li>Object to or restrict processing of your data.</li>
        <li>Request data portability.</li>
      </ul>
      <p>
        Since comments are stored on GitHub, you can delete your own comments directly through GitHub Discussions.
        For any other data-related requests, please reach out to me via
        <a href="https://www.linkedin.com/in/shameemreza/" target="_blank" rel="noopener noreferrer">LinkedIn</a>.
      </p>

      <h2>Hosting</h2>
      <p>
        This site is hosted on <a href="https://www.netlify.com" target="_blank" rel="noopener noreferrer">Netlify</a>.
        Netlify may collect server logs including your IP address. Please refer to
        <a href="https://www.netlify.com/privacy/" target="_blank" rel="noopener noreferrer">Netlify's privacy policy</a>
        for details.
      </p>

      <h2>Open source</h2>
      <p>
        The source code for this website is publicly available on
        <a href="https://github.com/shameemreza/shameemreza.com" target="_blank" rel="noopener noreferrer">GitHub</a>.
        If you spot an issue, feel free to open a pull request.
      </p>

      <h2>Changes to this policy</h2>
      <p>
        I may update this page from time to time. The "Last updated" date at the top reflects the most
        recent revision. Continued use of the site after changes constitutes acceptance of the updated policy.
      </p>
    </div>
  </main>
</BaseLayout>
