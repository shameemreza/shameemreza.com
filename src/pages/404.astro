---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const fallbackPosts = allPosts
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return b.data.date.getTime() - a.data.date.getTime();
  })
  .slice(0, 4);
---

<BaseLayout
  title="Page not found"
  description="The page you're looking for doesn't exist or has been moved."
>
  <main class="container">
    <section class="nf-hero">
      <div class="nf-canvas-wrap">
        <canvas id="nf-canvas" class="nf-canvas" aria-hidden="true"></canvas>
        <div class="nf-fallback" aria-hidden="true">404</div>
      </div>
      <h1 class="nf-title">This page doesn't exist.</h1>
      <p id="nf-context" class="nf-context">
        The page you're looking for has been moved, deleted, or never existed
        in the first place. If you followed a link from an old domain like
        <s>shameem.dev</s>, <s>shameem.blog</s>, or <s>shameem.me</s>,
        the URL structure may have changed.
      </p>

      <div class="nf-actions">
        <a href="/" class="nf-chip primary">Go home</a>
        <a href="/blog/" class="nf-chip">Read the blog</a>
        <button type="button" class="nf-chip" id="nf-search-btn" aria-label="Open search">
          Search posts
          <kbd class="nf-kbd" id="nf-search-kbd">&#8984;K</kbd>
        </button>
      </div>
    </section>

    <div class="section-divider">
      <h2 id="nf-related-intro" class="section-label">You might be looking for</h2>
      <a href="/blog/" class="section-more">All articles &rarr;</a>
    </div>

    <div id="nf-related" class="card-group nf-related">
      {
        fallbackPosts.map((post) => (
          <a href={`/${post.id}/`} class="hover-card nf-related-card">
            <div class="card-bg" />
            <div>
              <div class="nf-reason">Recent post</div>
              <h3 class="post-item-title">{post.data.title}</h3>
            </div>
            <div class="post-item-meta">{post.data.category}</div>
          </a>
        ))
      }
    </div>

    <p class="nf-domains">
      Previously <s>shameem.dev</s>, <s>shameem.blog</s>, <s>shameem.me</s>. Now here.
    </p>
  </main>

  <script is:inline>
  (function initNotFound() {
    const canvas = document.getElementById('nf-canvas');
    if (!canvas || !canvas.getContext) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let particles = [];
    const pointer = { x: -9999, y: -9999, active: false };
    let rafId = null;
    let running = false;

    function readColors() {
      const s = getComputedStyle(document.documentElement);
      return {
        base: s.getPropertyValue('--ink-sub').trim() || '#44403c',
        accent: s.getPropertyValue('--accent').trim() || '#0d9488',
      };
    }

    function resize() {
      const rect = canvas.getBoundingClientRect();
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = Math.floor(rect.width * dpr);
      canvas.height = Math.floor(rect.height * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      buildParticles(rect.width, rect.height);
    }

    function buildParticles(w, h) {
      if (w < 2 || h < 2) return;
      const off = document.createElement('canvas');
      off.width = Math.max(1, Math.floor(w));
      off.height = Math.max(1, Math.floor(h));
      const octx = off.getContext('2d');
      if (!octx) return;
      const fontSize = Math.min(h * 0.95, w * 0.4);
      octx.fillStyle = '#000';
      octx.font =
        '900 ' +
        fontSize +
        'px system-ui, -apple-system, "Segoe UI", Roboto, sans-serif';
      octx.textAlign = 'center';
      octx.textBaseline = 'middle';
      octx.fillText('404', w / 2, h / 2);

      const data = octx.getImageData(0, 0, off.width, off.height).data;
      const step = w < 420 ? 4 : 5;
      const targets = [];
      for (let y = 0; y < off.height; y += step) {
        for (let x = 0; x < off.width; x += step) {
          const i = (y * off.width + x) * 4 + 3;
          if (data[i] > 128) targets.push(x, y);
        }
      }

      const count = targets.length / 2;
      if (!particles.length || particles.length !== count) {
        particles = new Array(count);
        for (let i = 0; i < count; i++) {
          const tx = targets[i * 2];
          const ty = targets[i * 2 + 1];
          particles[i] = {
            x: tx + (Math.random() - 0.5) * w * 0.6,
            y: ty + (Math.random() - 0.5) * h * 0.6,
            vx: 0,
            vy: 0,
            tx: tx,
            ty: ty,
            r: Math.random() * 0.9 + 0.7,
            phX: Math.random() * Math.PI * 2,
            phY: Math.random() * Math.PI * 2,
            amp: 0.7 + Math.random() * 0.6,
          };
        }
      } else {
        for (let i = 0; i < count; i++) {
          particles[i].tx = targets[i * 2];
          particles[i].ty = targets[i * 2 + 1];
        }
      }
    }

    function tick() {
      const rect = canvas.getBoundingClientRect();
      ctx.clearRect(0, 0, rect.width, rect.height);
      const colors = readColors();
      const len = particles.length;
      const t = performance.now() * 0.001;
      const waveX = Math.sin(t * 0.55);
      const waveY = Math.cos(t * 0.45);

      for (let i = 0; i < len; i++) {
        const p = particles[i];

        const ox =
          Math.sin(t * 1.3 + p.phX) * 1.8 * p.amp +
          Math.sin(t * 0.7 + p.ty * 0.02) * 1.1 * waveX;
        const oy =
          Math.cos(t * 1.1 + p.phY) * 1.8 * p.amp +
          Math.sin(t * 0.6 + p.tx * 0.018) * 1.3 * waveY;

        const atx = p.tx + ox;
        const aty = p.ty + oy;
        const dx = atx - p.x;
        const dy = aty - p.y;
        p.vx = (p.vx + dx * 0.045) * 0.86;
        p.vy = (p.vy + dy * 0.045) * 0.86;

        if (pointer.active) {
          const px = p.x - pointer.x;
          const py = p.y - pointer.y;
          const d2 = px * px + py * py;
          if (d2 < 7200) {
            const d = Math.sqrt(d2) || 1;
            const force = (1 - d / 85) * 4.2;
            p.vx += (px / d) * force;
            p.vy += (py / d) * force;
          }
        }

        p.x += p.vx;
        p.y += p.vy;

        const speed2 = p.vx * p.vx + p.vy * p.vy;
        ctx.fillStyle = speed2 > 0.9 ? colors.accent : colors.base;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fill();
      }

      rafId = requestAnimationFrame(tick);
    }

    function start() {
      if (running) return;
      running = true;
      rafId = requestAnimationFrame(tick);
    }

    function stop() {
      running = false;
      if (rafId) cancelAnimationFrame(rafId);
      rafId = null;
    }

    function renderStatic() {
      const rect = canvas.getBoundingClientRect();
      ctx.clearRect(0, 0, rect.width, rect.height);
      ctx.fillStyle = readColors().base;
      for (let i = 0; i < particles.length; i++) {
        const p = particles[i];
        ctx.beginPath();
        ctx.arc(p.tx, p.ty, p.r, 0, Math.PI * 2);
        ctx.fill();
      }
    }

    resize();
    if (reduced) renderStatic();
    else start();

    let resizeTimer = null;
    window.addEventListener('resize', function () {
      if (resizeTimer) clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function () {
        resize();
        if (reduced) renderStatic();
      }, 120);
    });

    document.addEventListener('visibilitychange', function () {
      if (document.hidden) stop();
      else if (!reduced && !running) start();
    });

    canvas.addEventListener('pointermove', function (e) {
      const rect = canvas.getBoundingClientRect();
      pointer.x = e.clientX - rect.left;
      pointer.y = e.clientY - rect.top;
      pointer.active = true;
    });
    canvas.addEventListener('pointerleave', function () {
      pointer.active = false;
      pointer.x = -9999;
      pointer.y = -9999;
    });

    const searchKbd = document.getElementById('nf-search-kbd');
    if (searchKbd) {
      const isMac =
        typeof navigator !== 'undefined' &&
        /mac/i.test(navigator.platform || '');
      searchKbd.textContent = isMac ? '\u2318K' : 'Ctrl K';
    }

    const searchBtn = document.getElementById('nf-search-btn');
    if (searchBtn) {
      searchBtn.addEventListener('click', function () {
        const headerTrigger = document.getElementById('search-toggle');
        if (headerTrigger && typeof headerTrigger.click === 'function') {
          headerTrigger.click();
          return;
        }
        document.dispatchEvent(
          new KeyboardEvent('keydown', {
            key: 'k',
            ctrlKey: true,
            metaKey: true,
            bubbles: true,
          })
        );
      });
    }

    const path = window.location.pathname || '/';
    const referrer = document.referrer || '';
    const contextEl = document.getElementById('nf-context');
    const relatedEl = document.getElementById('nf-related');
    const relatedIntro = document.getElementById('nf-related-intro');

    const isOldWp =
      /^\/(\d{4}\/\d{1,2}\/|category\/|tag\/|author\/)/i.test(path) ||
      /\/wp-(content|admin|includes)\//i.test(path) ||
      /\?p=\d+/i.test(window.location.search || '');
    const isPostSlug = /^\/[a-z0-9][a-z0-9-]{3,}\/?$/i.test(path);
    const fromSearch =
      /\b(google|bing|duckduckgo|yahoo|ecosia|brave)\./i.test(referrer);

    if (contextEl) {
      let copy = null;
      if (isOldWp) {
        copy =
          "This looks like an old link from one of my previous domains. The URL structure changed when I moved everything here. Something below is probably what you wanted.";
      } else if (isPostSlug) {
        copy =
          "I've been trimming older posts, so this one may have been retired. Here's what's closest to what you were after.";
      } else if (fromSearch) {
        copy =
          "Search engines can lag behind when URLs change. The fresher pieces below are probably what you wanted.";
      }
      if (copy) contextEl.textContent = copy;
    }

    const STOP = {
      the: 1, a: 1, an: 1, of: 1, to: 1, and: 1, in: 1, for: 1, with: 1,
      is: 1, how: 1, your: 1, you: 1, my: 1, on: 1, at: 1, or: 1, by: 1,
      it: 1, be: 1, we: 1, are: 1, this: 1, that: 1, from: 1, as: 1,
      what: 1, why: 1, when: 1, where: 1, who: 1, which: 1, not: 1,
      do: 1, does: 1, did: 1, can: 1, will: 1, should: 1, into: 1,
      vs: 1, use: 1, using: 1, best: 1, top: 1, new: 1, old: 1,
    };

    function escapeHtml(str) {
      return String(str).replace(/[&<>"']/g, function (c) {
        return (
          { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[
            c
          ] || c
        );
      });
    }

    async function loadRelated() {
      if (!relatedEl) return;
      let posts;
      try {
        const res = await fetch('/search-index.json', { credentials: 'same-origin' });
        posts = await res.json();
      } catch (e) {
        return;
      }
      if (!Array.isArray(posts) || !posts.length) return;

      const lastSeg = (path.split('/').filter(Boolean).pop() || '').toLowerCase();
      const slug = lastSeg.replace(/\.[a-z0-9]+$/, '');
      const tokens = slug
        .split(/[-_]+/)
        .filter(function (t) {
          return t.length >= 3 && !STOP[t];
        });

      function scoreFor(post) {
        const title = (post.title || '').toLowerCase();
        const cat = (post.category || '').toLowerCase();
        const href = (post.href || '').toLowerCase();
        let s = 0;
        let titleHits = 0;
        let catHits = 0;
        for (let i = 0; i < tokens.length; i++) {
          const t = tokens[i];
          if (title.indexOf(t) > -1) {
            s += 3;
            titleHits++;
          }
          if (cat.indexOf(t) > -1) {
            s += 1;
            catHits++;
          }
        }
        if (slug && slug.length >= 4 && href.indexOf(slug) > -1) s += 5;
        return { s: s, titleHits: titleHits, catHits: catHits };
      }

      const scored = tokens.length
        ? posts
            .map(function (p) {
              const r = scoreFor(p);
              return { post: p, s: r.s, titleHits: r.titleHits, catHits: r.catHits };
            })
            .sort(function (a, b) {
              return b.s - a.s;
            })
        : [];

      const best = scored.filter(function (x) {
        return x.s >= 3;
      });

      let items;
      let introText;
      if (best.length) {
        items = best.slice(0, 4).map(function (x) {
          return {
            post: x.post,
            reason: x.titleHits
              ? 'Similar topic'
              : x.catHits
                ? 'Same category'
                : 'Related',
          };
        });
        introText = 'You might be looking for';
      } else {
        items = posts.slice(0, 4).map(function (p) {
          return { post: p, reason: 'Recent post' };
        });
        introText = "Here's what's new instead";
      }

      if (relatedIntro) relatedIntro.textContent = introText;

      const html = items
        .map(function (item) {
          const p = item.post;
          return (
            '<a href="' +
            escapeHtml(p.href) +
            '" class="hover-card nf-related-card">' +
            '<div class="card-bg"></div>' +
            '<div>' +
            '<div class="nf-reason">' +
            escapeHtml(item.reason) +
            '</div>' +
            '<h3 class="post-item-title">' +
            escapeHtml(p.title) +
            '</h3>' +
            '</div>' +
            '<div class="post-item-meta">' +
            escapeHtml(p.category || '') +
            '</div>' +
            '</a>'
          );
        })
        .join('');

      relatedEl.innerHTML = html;
    }

    loadRelated();
  })();
  </script>
</BaseLayout>
