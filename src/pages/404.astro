---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config';
---

<BaseLayout
  title="Page not found"
  description="The page you're looking for doesn't exist or has been moved."
>
  <main class="container">
    <div class="not-found">
      <p class="not-found-code">404</p>
      <h1>This page doesn't exist.</h1>
      <p class="not-found-desc">
        The page you're looking for has been moved, deleted, or never existed in the first place.
        If you followed a link from an old domain like <s>shameem.dev</s>, <s>shameem.blog</s>,
        or <s>shameem.me</s>, the URL structure may have changed.
      </p>
      <div class="not-found-actions">
        <a href="/" class="not-found-btn primary">Go home</a>
        <a href="/blog/" class="not-found-btn">Read the blog</a>
      </div>
    </div>
  </main>
</BaseLayout>
